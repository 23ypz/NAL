PORT=4000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=academic_light

# TiDB Cloud / cloud MySQL usually needs TLS
DB_ENABLE_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=please_change_to_a_long_random_secret

# Optional. Leave empty to allow all origins during course demo.
# Example: http://localhost:5173,https://your-project.vercel.app
CORS_ORIGIN=
